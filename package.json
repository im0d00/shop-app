{
  "name": "retail-os-pro",
  "version": "1.0.0",
  "description": "Premium Offline-First Desktop ERP/POS System for Fashion Retail",
  "main": "public/electron.js",
  "homepage": "./",
  "author": "Retail OS Team",
  "license": "COMMERCIAL",
  "private": true,
  "dependencies": {
    "ag-grid-community": "^30.0.0",
    "ag-grid-react": "^30.0.0",
    "axios": "^1.4.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "crypto-js": "^4.1.1",
    "date-fns": "^2.30.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^6.10.0",
    "framer-motion": "^10.16.4",
    "helmet": "^7.0.0",
    "jsonwebtoken": "^9.0.1",
    "jspdf": "^2.5.1",
    "lodash": "^4.17.21",
    "lucide-react": "^0.263.1",
    "pdfkit": "^0.13.0",
    "pg": "^8.11.1",
    "qs": "^6.11.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.14.2",
    "recharts": "^2.7.3",
    "socket.io": "^4.6.2",
    "socket.io-client": "^4.6.2",
    "tailwindcss": "^3.3.3",
    "uuid": "^9.0.0",
    "validator": "^13.9.0",
    "xlsx": "^0.18.5",
    "zustand": "^4.3.9"
  },
  "devDependencies": {
    "@tailwindcss/forms": "^0.5.10",
    "@types/node": "^20.3.1",
    "@types/react": "^18.2.14",
    "autoprefixer": "^10.4.14",
    "concurrently": "^8.2.0",
    "electron": "^25.1.0",
    "electron-builder": "^24.4.0",
    "electron-is-dev": "^2.0.0",
    "nodemon": "^3.0.1",
    "postcss": "^8.4.24",
    "react-scripts": "^5.0.1",
    "wait-on": "^7.0.1"
  },
  "scripts": {
    "start": "concurrently \"npm run backend\" \"npm run frontend\" \"npm run electron-dev\"",
    "backend": "nodemon src/backend/server.js",
    "frontend": "react-scripts start",
    "electron-dev": "wait-on http://localhost:3000 http://localhost:5000 && electron .",
    "build": "npm run build:backend && npm run build:frontend",
    "build:backend": "echo 'Backend build complete'",
    "build:frontend": "react-scripts build",
    "build:electron": "electron-builder --publish=never",
    "dist": "npm run build && npm run build:electron",
    "test": "react-scripts test --watchAll=false --passWithNoTests"
  },
  "electron-builder": {
    "appId": "com.retailospro.shop",
    "productName": "Retail OS Pro",
    "directories": {
      "buildResources": "public"
    },
    "files": [
      "build/**/*",
      "public/electron.js",
      "src/backend/**/*",
      "node_modules/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
