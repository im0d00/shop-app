# Backend Configuration
NODE_ENV=production
PORT=5000
DATABASE_URL=postgresql://retailos:password@localhost:5432/retailos_db

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRY=24h

# License Configuration
LICENSE_SECRET=your-license-secret-key
LICENSE_SERVER=https://license.retailospro.com

# Electron Configuration
ELECTRON_START_URL=http://localhost:3000
ELECTRON_DEV=true

# App Configuration
APP_NAME=Retail OS Pro
APP_VERSION=1.0.0
BUILD_NUMBER=1001

# Security
BCRYPT_ROUNDS=10
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX_REQUESTS=100

# File Storage
BACKUP_DIR=./backups
LOG_DIR=./logs

# Features
ENABLE_CLOUD_SYNC=false
ENABLE_OFFLINE_MODE=true
ENABLE_LOCAL_NETWORK=true
